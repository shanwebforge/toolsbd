# ========================================
# TAILWIND CSS PROJECT - .gitignore
# ========================================

# ?? NEVER PUSH TO GITHUB
node_modules/          # 100MB+ dependencies

# ?? SECURITY - API keys, passwords
.env
.env.local
.env.*.local

# ??? OPERATING SYSTEM FILES
.DS_Store              # macOS
Thumbs.db              # Windows
desktop.ini            # Windows

# ?? DEBUG 
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ?? IDE/EDITOR FILES
.vscode/
.idea/
*.swp
*.swo

# ?? TEMPORARY/BUILD FILES
*.tmp
*.temp
# dist/                # Commented - we need dist/output.css

# ========================================
# IMPORTANT: dist/output.css will be PUSHED
# This is required for deployment
# ========================================
